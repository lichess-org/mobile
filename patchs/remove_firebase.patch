diff --git a/lib/src/firebase_stubs.dart b/lib/src/firebase_stubs.dart
new file mode 100644
index 000000000..aa278d12a
--- /dev/null
+++ b/lib/src/firebase_stubs.dart
@@ -0,0 +1,20 @@
+import 'package:flutter/foundation.dart';
+
+class FirebaseCrashlytics {
+  static FirebaseCrashlytics instance = FirebaseCrashlytics();
+
+  Future<void> recordError(
+    dynamic exception,
+    StackTrace? stack, {
+    dynamic reason,
+    Iterable<Object> information = const [],
+    bool? printDetails,
+    bool fatal = false,
+  }) {
+    return Future.value();
+  }
+
+  void recordFlutterFatalError(FlutterErrorDetails flutterErrorDetails) {
+    return FlutterError.presentError(flutterErrorDetails);
+  }
+}
